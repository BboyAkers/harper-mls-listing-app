{
	"name": "harper-mls-listings",
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"agent:run": "npx -y @harperfast/agent@latest",
		"agent:skills:update": "npx -y skills@latest add harperfast/skills --all --yes",
		"start": "harper run .",
		"dev": "harper dev .",
		"generate:seed": "node scripts/generate-seed.mjs",
		"seed": "curl -s -X POST http://localhost:9926/Seed | cat",
		"lint": "eslint .",
		"format": "prettier --write .",
		"test": "node --test test/*.test.ts",
		"test:watch": "node --watch --test test/*.test.ts",
		"build": "vite build",
		"deploy": "harper deploy_component . restart=true replicated=true"
	},
	"dependencies": {
		"@harperfast/schema-codegen": "^1.0.10",
		"@harperfast/vite": "^1.1.0",
		"@radix-ui/react-dialog": "^1.1.19",
		"@radix-ui/react-label": "^2.1.11",
		"@radix-ui/react-select": "^2.3.3",
		"@radix-ui/react-separator": "^1.1.11",
		"@radix-ui/react-slider": "^1.4.3",
		"@radix-ui/react-slot": "^1.3.0",
		"@radix-ui/react-tabs": "^1.1.17",
		"@radix-ui/react-toggle-group": "^1.1.15",
		"@radix-ui/react-tooltip": "^1.2.12",
		"@vitejs/plugin-react": "^6.0.1",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"leaflet": "^1.9.4",
		"lucide-react": "^1.24.0",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"react-leaflet": "^5.0.0",
		"sonner": "^2.0.7",
		"tailwind-merge": "^3.6.0",
		"vite": "^8.0.0",
		"tailwindcss": "^4.3.2",
		"@tailwindcss/vite": "^4.3.2"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@types/leaflet": "^1.9.21",
		"@types/node": "^24.10.1",
		"@types/react": "^19.2.10",
		"@types/react-dom": "^19.2.3",
		"eslint": "^10.0.2",
		"globals": "^17.4.0",
		"prettier": "^3.8.1",
		"tw-animate-css": "^1.4.0",
		"typescript": "~6.0.0"
	}
}
